[Desktop Entry]
Version=1.0
Type=Application
Name=Start APRS
Comment=Restart APRS kiosk browser
Exec=/bin/bash -c 'pkill chromium 2>/dev/null; sleep 1; chromium --password-store=basic --kiosk --noerrdialogs --disable-infobars --disable-dev-shm-usage --incognito https://marsaprs.org/'
Icon=chromium
Terminal=false
Categories=Application;
