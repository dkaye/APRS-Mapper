/var/log/aprs-backup.log {
    daily
    rotate 7
    compress
    missingok
    notifempty
    copytruncate
    create 0644 root root
}

/var/log/aprs-daemon/daemon.log {
    daily
    rotate 7
    compress
    missingok
    notifempty
    copytruncate
    create 0644 www-data www-data
}

/var/log/netbird-poller.log {
    daily
    rotate 7
    compress
    missingok
    notifempty
    copytruncate
    create 0644 www-data www-data
}
