+        foreach ($history as $ts) {
+            $L[] = '# ' . $ts;
+        }
+    }
+    $L[] = '';
+    $event = trim($cfg['event'] ?? '');
+    if ($event !== '') {
+        $L[] = '# ── Event ─────────────────────────────────────────────────────────────────────';
