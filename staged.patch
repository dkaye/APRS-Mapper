+        $L[] = '';
+    }
+    $legend = trim($cfg['legend'] ?? '');
+    if ($legend !== '') {
+        $L[] = '# ── Legend ────────────────────────────────────────────────────────────────────';
+        $L[] = '# HTML displayed in the lower-left corner of the map in kiosk mode.';
